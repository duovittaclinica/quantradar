generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Plan {
  id                   String   @id @default(cuid())
  name                 String   @unique
  stripePriceIdMonthly String?
  maxAssets            Int      @default(10)
  maxAlerts            Int      @default(5)
  maxAiDaily           Int      @default(3)
  cacheSeconds         Int      @default(300)
  backtestDays         Int      @default(30)
  createdAt            DateTime @default(now())
  users                User[]

  @@map("qr_plans")
}

model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  name                 String?
  passwordHash         String?
  role                 String   @default("USER")
  plan                 String   @default("FREE")
  profile              String   @default("MODERADO")
  planId               String?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  aiUsageToday         Int      @default(0)
  aiUsageResetAt       DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  planRelation         Plan?    @relation(fields: [planId], references: [id])
  watchlists           Watchlist[]
  alerts               Alert[]
  signals              Signal[]
  aiUsage              AiUsage[]

  @@map("qr_users")
}

model Asset {
  id        String   @id @default(cuid())
  ticker    String   @unique
  name      String
  type      String   @default("ACAO")
  sector    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  signals   Signal[]
  watchlistItems WatchlistItem[]
  alerts    Alert[]

  @@map("qr_assets")
}

model Signal {
  id            String   @id @default(cuid())
  assetId       String?
  userId        String?
  score         Float
  tag           String
  profile       String   @default("MODERADO")
  breakdown     Json     @default("{}")
  justification Json     @default("[]")
  risks         Json     @default("[]")
  targetPrice   Float?
  stopLoss      Float?
  horizon       String?
  confidence    Float    @default(0)
  weights       Json     @default("{}")
  price         Float    @default(0)
  generatedAt   DateTime @default(now())
  asset         Asset?   @relation(fields: [assetId], references: [id])
  user          User?    @relation(fields: [userId], references: [id])

  @@map("qr_signals")
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("Principal")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  items     WatchlistItem[]

  @@map("qr_watchlists")
}

model WatchlistItem {
  id          String   @id @default(cuid())
  watchlistId String
  assetId     String
  addedAt     DateTime @default(now())
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id])
  asset       Asset    @relation(fields: [assetId], references: [id])

  @@unique([watchlistId, assetId])
  @@map("qr_watchlist_items")
}

model Alert {
  id            String    @id @default(cuid())
  userId        String
  assetId       String?
  type          String
  condition     Json      @default("{}")
  channels      String[]  @default(["panel"])
  active        Boolean   @default(true)
  triggered     Boolean   @default(false)
  message       String?
  lastTriggered DateTime?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id])
  asset         Asset?    @relation(fields: [assetId], references: [id])

  @@map("qr_alerts")
}

model NewsCache {
  id             String   @id @default(cuid())
  title          String
  description    String?
  url            String   @unique
  source         String
  sentiment      String   @default("neutro")
  sentimentScore Float    @default(0)
  tickers        String[] @default([])
  publishedAt    DateTime
  cachedAt       DateTime @default(now())

  @@map("qr_news_cache")
}

model JobLog {
  id         String   @id @default(cuid())
  jobName    String
  status     String
  durationMs Int      @default(0)
  itemCount  Int?
  error      String?
  createdAt  DateTime @default(now())

  @@map("qr_job_logs")
}

model AiUsage {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @default(now())
  count  Int      @default(0)
  user   User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("qr_ai_usage")
}
