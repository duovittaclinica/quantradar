generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Plan {
  id                String   @id @default(cuid())
  name              String   @unique
  displayName       String
  price             Float    @default(0)
  watchlistLimit    Int      @default(10)
  alertsLimit       Int      @default(5)
  backtestingDays   Int      @default(30)
  aiAnalysisLimit   Int      @default(3)
  radarRefreshSecs  Int      @default(300)
  apiAccess         Boolean  @default(false)
  whiteLabel        Boolean  @default(false)
  createdAt         DateTime @default(now())
  users             User[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          UserRole  @default(USER)
  planId        String
  plan          Plan      @relation(fields: [planId], references: [id])
  planExpiresAt DateTime?
  profile       InvestorProfile @default(MODERADO)
  timezone      String    @default("America/Sao_Paulo")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  watchlists    Watchlist[]
  alerts        Alert[]
  signalViews   SignalView[]
  aiUsage       AiUsageLog[]
}

enum UserRole { USER PRO PREMIUM ADMIN }
enum InvestorProfile { CONSERVADOR MODERADO AGRESSIVO DIVIDENDOS VALORIZACAO CURTO_PRAZO LONGO_PRAZO }

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Asset {
  id             String    @id @default(cuid())
  ticker         String    @unique
  name           String
  type           AssetType
  sector         String?
  exchange       String?   @default("B3")
  currency       String    @default("BRL")
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  quotes         Quote[]
  signals        Signal[]
  watchlistItems WatchlistItem[]
  alerts         Alert[]
  newsLinks      NewsAssetLink[]
}

enum AssetType { ACAO FII ETF BDR CRIPTO INDICE RENDA_FIXA }

model Quote {
  id            String   @id @default(cuid())
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id])
  price         Float
  open          Float?
  high          Float?
  low           Float?
  close         Float?
  previousClose Float?
  change        Float?
  changePercent Float?
  volume        BigInt?
  marketCap     Float?
  rsi14         Float?
  macd          Float?
  macdSignal    Float?
  macdHistogram Float?
  ma20          Float?
  ma50          Float?
  ma200         Float?
  bbUpper       Float?
  bbMiddle      Float?
  bbLower       Float?
  atr           Float?
  adx           Float?
  pl            Float?
  pvp           Float?
  dividendYield Float?
  roe           Float?
  roic          Float?
  ebitdaMargin  Float?
  netMargin     Float?
  debtToEquity  Float?
  source        String   @default("BRAPI")
  fetchedAt     DateTime @default(now())
  tradingDate   DateTime
  @@index([assetId, tradingDate])
}

model Signal {
  id                String    @id @default(cuid())
  assetId           String
  asset             Asset     @relation(fields: [assetId], references: [id])
  score             Float
  tag               SignalTag
  technicalScore    Float
  fundamentalScore  Float
  sentimentScore    Float
  liquidityScore    Float
  technicalWeight   Float
  fundamentalWeight Float
  sentimentWeight   Float
  liquidityWeight   Float
  justification     Json
  risks             Json
  priceAtSignal     Float
  targetPrice       Float?
  stopLoss          Float?
  horizon           String?
  generatedAt       DateTime  @default(now())
  expiresAt         DateTime?
  views             SignalView[]
}

enum SignalTag { COMPRA_FORTE COMPRA_MODERADA AGUARDAR ALTO_RISCO VENDA }

model SignalView {
  id       String   @id @default(cuid())
  userId   String
  signalId String
  viewedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  signal   Signal   @relation(fields: [signalId], references: [id])
  @@unique([userId, signalId])
}

model Watchlist {
  id        String          @id @default(cuid())
  userId    String
  name      String          @default("Minha Watchlist")
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WatchlistItem[]
}

model WatchlistItem {
  id          String    @id @default(cuid())
  watchlistId String
  assetId     String
  addedAt     DateTime  @default(now())
  notes       String?
  targetPrice Float?
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  asset       Asset     @relation(fields: [assetId], references: [id])
  @@unique([watchlistId, assetId])
}

model Alert {
  id          String      @id @default(cuid())
  userId      String
  assetId     String?
  type        AlertType
  condition   Json
  message     String?
  channels    String[]    @default(["panel"])
  active      Boolean     @default(true)
  triggered   Boolean     @default(false)
  triggeredAt DateTime?
  createdAt   DateTime    @default(now())
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset       Asset?      @relation(fields: [assetId], references: [id])
}

enum AlertType { SCORE_THRESHOLD PRICE_TARGET PRICE_DROP VOLUME_SPIKE TREND_CHANGE BREAKOUT NEWS_SENTIMENT DIVIDEND_ANNOUNCED }

model NewsArticle {
  id             String   @id @default(cuid())
  externalId     String?  @unique
  title          String
  description    String?  @db.Text
  url            String?
  source         String
  publishedAt    DateTime
  fetchedAt      DateTime @default(now())
  sentiment      String?
  sentimentScore Float?
  impactLevel    String?
  keywords       String[]
  assets         NewsAssetLink[]
}

model NewsAssetLink {
  newsId  String
  assetId String
  news    NewsArticle @relation(fields: [newsId], references: [id])
  asset   Asset       @relation(fields: [assetId], references: [id])
  @@id([newsId, assetId])
}

model AiUsageLog {
  id           String   @id @default(cuid())
  userId       String
  type         String
  inputTokens  Int
  outputTokens Int
  model        String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model JobLog {
  id        String   @id @default(cuid())
  jobName   String
  status    String
  message   String?  @db.Text
  duration  Int?
  itemCount Int?
  createdAt DateTime @default(now())
  @@index([jobName, createdAt])
}
