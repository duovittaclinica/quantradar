generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model QrPlan {
  id           String   @id @default(cuid())
  name         String   @unique
  maxAssets    Int      @default(10)
  maxAlerts    Int      @default(5)
  maxAiDaily   Int      @default(3)
  cacheSeconds Int      @default(300)
  backtestDays Int      @default(30)
  createdAt    DateTime @default(now())

  @@map("plans")
  @@schema("qr")
}

model QrUser {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  passwordHash     String?  @map("password_hash")
  role             String   @default("USER")
  plan             String   @default("FREE")
  profile          String   @default("MODERADO")
  planId           String?  @map("plan_id")
  aiUsageToday     Int      @default(0) @map("ai_usage_today")
  aiUsageResetAt   DateTime @default(now()) @map("ai_usage_reset_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  watchlists       QrWatchlist[]
  alerts           QrAlert[]
  signals          QrSignal[]

  @@map("users")
  @@schema("qr")
}

model QrAsset {
  id        String   @id @default(cuid())
  ticker    String   @unique
  name      String
  type      String   @default("ACAO")
  sector    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  signals   QrSignal[]
  watchlistItems QrWatchlistItem[]
  alerts    QrAlert[]

  @@map("assets")
  @@schema("qr")
}

model QrSignal {
  id           String   @id @default(cuid())
  assetId      String?  @map("asset_id")
  userId       String?  @map("user_id")
  score        Float
  tag          String
  profile      String   @default("MODERADO")
  breakdown    Json     @default("{}")
  justification Json    @default("[]")
  risks        Json     @default("[]")
  targetPrice  Float?   @map("target_price")
  stopLoss     Float?   @map("stop_loss")
  horizon      String?
  confidence   Float    @default(0)
  weights      Json     @default("{}")
  price        Float    @default(0)
  generatedAt  DateTime @default(now()) @map("generated_at")
  asset        QrAsset? @relation(fields: [assetId], references: [id])
  user         QrUser?  @relation(fields: [userId], references: [id])

  @@map("signals")
  @@schema("qr")
}

model QrWatchlist {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String   @default("Principal")
  createdAt DateTime @default(now()) @map("created_at")
  user      QrUser   @relation(fields: [userId], references: [id])
  items     QrWatchlistItem[]

  @@map("watchlists")
  @@schema("qr")
}

model QrWatchlistItem {
  id          String   @id @default(cuid())
  watchlistId String   @map("watchlist_id")
  assetId     String   @map("asset_id")
  addedAt     DateTime @default(now()) @map("added_at")
  watchlist   QrWatchlist @relation(fields: [watchlistId], references: [id])
  asset       QrAsset  @relation(fields: [assetId], references: [id])

  @@unique([watchlistId, assetId])
  @@map("watchlist_items")
  @@schema("qr")
}

model QrAlert {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  assetId       String?  @map("asset_id")
  type          String
  condition     Json     @default("{}")
  channels      String[] @default(["panel"])
  active        Boolean  @default(true)
  triggered     Boolean  @default(false)
  message       String?
  lastTriggered DateTime? @map("last_triggered_at")
  createdAt     DateTime @default(now()) @map("created_at")
  user          QrUser   @relation(fields: [userId], references: [id])
  asset         QrAsset? @relation(fields: [assetId], references: [id])

  @@map("alerts")
  @@schema("qr")
}

model QrNewsCache {
  id             String   @id @default(cuid())
  title          String
  description    String?
  url            String   @unique
  source         String
  sentiment      String   @default("neutro")
  sentimentScore Float    @default(0) @map("sentiment_score")
  tickers        String[] @default([])
  publishedAt    DateTime @map("published_at")
  cachedAt       DateTime @default(now()) @map("cached_at")

  @@map("news_cache")
  @@schema("qr")
}

model QrJobLog {
  id        String   @id @default(cuid())
  jobName   String   @map("job_name")
  status    String
  durationMs Int     @default(0) @map("duration_ms")
  itemCount Int?     @map("item_count")
  error     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("job_logs")
  @@schema("qr")
}