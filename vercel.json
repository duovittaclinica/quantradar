{
  "version": 2,
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/radar-update",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/alert-check",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/news-refresh",
      "schedule": "0 8 * * *"
    }
  ]
}